# App identity (rename per app)
APP_NAME=Template App
SERVICE_NAME=template-api
PUBLIC_API_BASE_URL=http://localhost:8000

# Runtime
NODE_ENV=development
PORT=8000
LOG_LEVEL=info

# Security (required)
JWT_SECRET=replace_with_a_long_random_secret

# Database (preferred for Railway)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app_template_db
# Set to true if your provider requires SSL in development
DATABASE_SSL=false

# Local database fallback (used if DATABASE_URL is omitted)
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=app_template_db

# Network and abuse controls
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8100
RATE_LIMIT_MAX=100

# Third-party service secrets (set only what your app uses)
GITHUB_TOKEN=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
RESEND_API_KEY=

# Apple App Store / subscriptions (optional)
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_KEY_PATH=./certificates/AuthKey_KEYID.p8
